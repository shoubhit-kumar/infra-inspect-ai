# ─── LLM Providers ────────────────────────────────
# Get a free Gemini key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: Watsonx for text-heavy workflows
# WATSONX_API_KEY=your-watsonx-key
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_PROJECT_ID=your-project-id

# Optional: Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-key

# ─── Provider routing ─────────────────────────────
DEFAULT_LLM_PROVIDER=gemini
VISION_LLM_PROVIDER=gemini

# ─── Tracing (optional but recommended) ───────────
# Sign up at https://langfuse.com or self-host
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── HuggingFace ──────────────────────────────────
# Get a token at https://huggingface.co/settings/tokens (Read scope is enough)
# Suppresses unauthenticated-request warnings and avoids rate limits.
HF_TOKEN=hf_your_token_here

# ─── RAG tuning ───────────────────────────────────
# Calibrated empirically (Day 19); see README evaluation section
MIN_RETRIEVAL_SCORE=0.05

# ─── App config ───────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development